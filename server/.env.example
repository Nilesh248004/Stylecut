# Notification Mode: 'mock' | 'email' | 'twilio' | 'meta'
# mock = Console logging (FREE, development)
# email = Email notifications (FREE if SMTP configured)
# twilio = Twilio WhatsApp (PAID)
# meta = Meta WhatsApp Cloud API (FREE tier: 1000 msgs/month)
NOTIFICATION_MODE=mock

# Twilio WhatsApp (PAID - production)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Cloud API (FREE tier - 1000 msgs/month)
# META_PHONE_NUMBER_ID=your_phone_number_id
# META_BUSINESS_ACCOUNT_ID=your_business_account_id
# META_ACCESS_TOKEN=your_access_token
# META_TEMPLATE_LANGUAGE=en_US
# META_BOOKING_CONFIRMATION_TEMPLATE=booking_confirmation
# META_BOOKING_ACCEPTED_TEMPLATE=booking_accepted
# META_BOOKING_COMPLETED_TEMPLATE=booking_completed

# Email Notifications (FREE if you have SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@stylecut.com
